{
  "name": "llmfy",
  "version": "0.0.1",
  "description": "CLI to check which LLMs you can run on your machine and expected performance",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "llmfy": "./bin/cli.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "llm",
    "cli",
    "hardware",
    "vram",
    "local-ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "systeminformation": "^5.23.17"
  }
}
